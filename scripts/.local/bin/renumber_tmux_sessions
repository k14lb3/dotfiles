#!/usr/bin/env bash

# ═══════════════════════════════════════════════════
# ░█▀▀█ ░█▀▀▀ ░█▄ ░█ ░█ ░█ ░█▀▄▀█ ░█▀▀█ ░█▀▀▀ ░█▀▀█
# ░█▄▄▀ ░█▀▀▀ ░█░█░█ ░█ ░█ ░█░█░█ ░█▀▀▄ ░█▀▀▀ ░█▄▄▀
# ░█ ░█ ░█▄▄▄ ░█  ▀█  ▀▄▄▀ ░█  ░█ ░█▄▄█ ░█▄▄▄ ░█ ░█
#
# ▀▀█▀▀ ░█▀▄▀█ ░█ ░█ ▀▄░▄▀
#  ░█   ░█░█░█ ░█ ░█  ░█
#  ░█   ░█  ░█  ▀▄▄▀ ▄▀░▀▄
#
# ░█▀▀▀█ ░█▀▀▀ ░█▀▀▀█ ░█▀▀▀█ ▀█▀ ░█▀▀▀█ ░█▄ ░█ ░█▀▀▀█
#  ▀▀▀▄▄ ░█▀▀▀  ▀▀▀▄▄  ▀▀▀▄▄ ░█  ░█  ░█ ░█░█░█  ▀▀▀▄▄
# ░█▄▄▄█ ░█▄▄▄ ░█▄▄▄█ ░█▄▄▄█ ▄█▄ ░█▄▄▄█ ░█  ▀█ ░█▄▄▄█
# ═══════════════════════════════════════════════════

main() {
  local -a SESSIONS=($(tmux list-sessions -F "#{session_name}" | grep '^[0-9]\+$' | sort -n))

  for INDEX in "${!SESSIONS[@]}"; do
    tmux rename-session -t "${SESSIONS[${INDEX}]}" "$((INDEX + 1))"
  done
}

main "$@"
