source "$(tmux display-message -p "#{config_files}" | xargs dirname)/status/globals"

main() {
  local component=""
  component+="#[fg=${COLORS[RED]}]"
  component+="${ICONS[SHADE]} "
  component+="${ICONS[FOLDER]} "
  component+="#[fg=${COLORS[FOREGROUND]}]"
